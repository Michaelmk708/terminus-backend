# Backend Environment Variables
# Copy this file to .env and fill in your values

# ═══════════════════════════════════════════════════════════════════
# SOLANA CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# RPC Endpoint
SOLANA_RPC_ENDPOINT=https://api.devnet.solana.com

# Network: devnet or mainnet-beta
SOLANA_NETWORK=devnet

# Terminus Smart Contract Program ID
TERMINUS_PROGRAM_ID=EYjKKn4Qhjv2d2fE9yggedBdLJBPHiumwfbVLtofMMsb

# ═══════════════════════════════════════════════════════════════════
# AI ORACLE CONFIGURATION (CRITICAL - DO NOT EXPOSE)
# ═══════════════════════════════════════════════════════════════════

# Path to Oracle keypair (JSON format)
# Generate via: solana-keygen new -o terminus_oracle_keypair.json
# Then add to .gitignore: terminus_oracle_keypair.json
ORACLE_KEYPAIR_PATH=./terminus_oracle_keypair.json

# ═══════════════════════════════════════════════════════════════════
# CHALLENGE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# Stake amount for challenges (in lamports)
# 5000000 = 0.005 SOL
CHALLENGE_STAKE_LAMPORTS=5000000

# Challenge timeout (in seconds)
# For demo: 5 seconds
# For production: 2592000 (30 days)
CHALLENGE_TIMEOUT_SECONDS=2592000

# ═══════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# SQLite database URL
DATABASE_URL=sqlite:///./terminus.db

# ═══════════════════════════════════════════════════════════════════
# EMAIL CONFIGURATION (for notifications)
# ═══════════════════════════════════════════════════════════════════

# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# NOTIFICATIONS_EMAIL_FROM=noreply@terminus.app

# ═══════════════════════════════════════════════════════════════════
# API CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# Backend API host and port
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════════════
# SECURITY
# ═══════════════════════════════════════════════════════════════════

# JWT secret for session management
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ═══════════════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════════════

# LOG_LEVEL=INFO
# LOG_FILE=./logs/terminus.log

# ═══════════════════════════════════════════════════════════════════
# NOTES
# ═══════════════════════════════════════════════════════════════════

# 1. NEVER commit .env to git
# 2. Add .env to .gitignore
# 3. Add terminus_oracle_keypair.json to .gitignore
# 4. Use different values for staging/production
# 5. Store secrets in environment variables or secrets manager in production
